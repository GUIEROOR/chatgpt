={}){const headers=Object.assign({'X-IPA-Local-Token':TOKEN},opt.headers||{});if(opt.body&&typeof opt.body!=='string'){headers['Content-Type']='application/json';opt.body=JSON.stringify(Object.assign({token:TOKEN},opt.body))}const r=await fetch(path,Object.assign({},opt,{headers}));const ct=r.headers.get('content-type')||'';let data;try{data=ct.includes('json')?await r.json():await r.text()}catch(e){data=''}if(!r.ok||data&&data.success===false){const err=new Error(data&&data.error||data&&data.message||('HTTP '+r.status));if(data&&typeof data==='object'){err.code=data.code||'';err.requiresTwoFactor=!!data.requiresTwoFactor}throw err}return data&&data.data!==undefined?data.data:data}
function bytes(n){n=Number(n||0);if(!n)return '未知';const u=['B','KB','MB','GB'];let i=0;while(n>=1024&&i<u.length-1){n/=1024;i++}return n.toFixed(i>1?2:0)+' '+u[i]}
function dateText(v){if(!v)return '未知';try{return new Date(v).toLocaleString('zh-CN',{month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit'})}catch(e){return v}}
function health(ok,text){$('#healthDot').className='dot '+(ok?'good':'');$('#healthText').textContent=text}
function renderAccounts(s){const box=$('#accountBox');if(!s.accounts.length){box.className='empty';box.innerHTML='尚未登录 Apple ID';return}box.className='list';box.innerHTML=s.accounts.map(a=>'<div class="account"><div class="account-main"><strong>'+esc(a.displayName||a.appleId)+'</strong><div class="account-meta">'+esc(a.appleId)+' · Store '+esc(a.storeFront||'未知')+' · <span class="'+(a.sessionStatus==='active'?'goodtext':a.sessionStatus==='expired'?'badtext':'warntext')+'">'+esc(a.sessionStatus||'未知')+'</span></div></div><div class="actions"><button class="secondary smallbtn js-switch" data-id="'+esc(a.appleId)+'">'+(s.activeAccount&&s.activeAccount.appleId===a.appleId?'当前账号':'切换')+'</button><button class="ghost smallbtn js-remove-account" data-id="'+esc(a.appleId)+'">移除</button></div></div>').join('')}
function normalizeCountryInput(value){const raw=String(value||'').trim().toLowerCase().replace(/_/g,'-');const aliases={zh:'cn','zh-cn':'cn','cn-zh':'cn','中国':'cn','中国大陆':'cn',china:'cn',mainland:'cn','zh-hans':'cn',hk:'hk','zh-hk':'hk','香港':'hk',mo:'mo','zh-mo':'mo','澳门':'mo',tw:'tw','zh-tw':'tw','zh-hant':'tw','台湾':'tw','臺灣':'tw',us:'us','en-us':'us','美国':'us',jp:'jp','ja-jp':'jp','日本':'jp',kr:'kr','ko-kr':'kr','韩国':'kr',sg:'sg','新加坡':'sg'};return aliases[raw]||(/^[a-z]{2}$/.test(raw)?raw:'')}
function renderSearchHistory(items){const el=$('#searchHistory');el.innerHTML=(items||[]).map(x=>'<button class="chip js-history" data-term="'+esc(x.term)+'" data-country="'+esc(x.country||'')+'">'+esc(x.term)+' · '+esc((x.country||'').toUpperCase())+'</button>').join('')}
function renderFavorites(items){const el=$('#favorites');el.innerHTML=items&&items.length?items.map(a=>'<div class="list-item"><div class="text"><strong>'+esc(a.name||a.appId)+'</strong><small>'+esc(a.bundleId||'')+'</small></div><button class="secondary smallbtn js-favorite-open" data-id="'+esc(a.appId)+'" data-name="'+esc(a.name||'App')+'">版本</button></div>').join(''):'<div class="empty">暂无收藏</div>'}
function renderDownloads(items){const el=$('#downloadHistory');el.innerHTML=items&&items.length?items.map(a=>'<div class="list-item"><div class="text"><strong>'+esc(a.name)+' '+esc(a.displayVersion||'')+'</strong><small>'+bytes(a.fileSize)+' · '+dateText(a.preparedAt)+'</small></div><button class="secondary smallbtn js-history-download" data-id="'+esc(a.appId)+'" data-version="'+esc(a.externalVersionId)+'">再次准备</button></div>').join(''):'<div class="empty">暂无记录</div>'}
function renderDiagnostics(d){const el=$('#diagnostics');if(!d||!d.results||!d.results.length){el.innerHTML='<div class="empty">尚未检测</div>';return}el.innerHTML=d.results.map(x=>'<div class="diag-row"><span>'+esc(x.name)+'</span><strong class="'+(x.ok?'goodtext':'badtext')+'">'+(x.ok?'正常':'失败')+(x.elapsedMs?' · '+x.elapsedMs+'ms':'')+'</strong></div>').join('')+'<div class="sub">检测时间：'+dateText(d.lastRunAt)+'</div>'}
async function refresh(){try{const s=await api('/api/status');model.status=s;renderAccounts(s);renderSearchHistory(s.searchHistory);renderFavorites(s.favorites);renderDownloads(s.downloadHistory);renderDiagnostics(s.diagnostics);$('#settingCountry').value=s.settings.country;$('#cacheHours').value=s.settings.cacheHours;$('#modeInfo').textContent='原版接口兼容：'+(s.settings.compatMode?'已开启':'已关闭')+' · 自动刷新密码：'+(s.settings.rememberPassword?'允许保存':'不保存')+' · 重试次数：'+s.settings.maxRetry;health(true,s.activeAccount?'已登录':'服务正常')}catch(e){health(false,'服务异常');showStatus(e.message,'error')}}
function appCard(a){const favorite=model.status&&model.status.favorites&&model.status.favorites.some(x=>String(x.appId)===String(a.appId));return '<article class="app"><img src="'+esc(a.icon||'')+'" alt=""><div><h3>'+esc(a.name)+'</h3><div class="meta">ID '+esc(a.appId)+' · 