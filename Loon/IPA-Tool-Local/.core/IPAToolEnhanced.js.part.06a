    var rememberJson = JSON.stringify(!!state.settings.rememberPassword);
    return `<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<meta name="color-scheme" content="light dark">
<title>IPA Tool Enhanced</title>
<style>
:root{font-family:-apple-system,BlinkMacSystemFont,"SF Pro Text","PingFang SC",sans-serif;color-scheme:light dark;--bg:#f4f6fb;--card:rgba(255,255,255,.82);--card2:rgba(255,255,255,.58);--text:#101828;--muted:#667085;--line:rgba(16,24,40,.1);--accent:#2563eb;--accent2:#7c3aed;--good:#15803d;--warn:#b45309;--danger:#dc2626;--shadow:0 18px 55px rgba(15,23,42,.08)}
@media(prefers-color-scheme:dark){:root{--bg:#080c14;--card:rgba(20,27,39,.84);--card2:rgba(20,27,39,.55);--text:#f8fafc;--muted:#94a3b8;--line:rgba(255,255,255,.11);--accent:#60a5fa;--accent2:#a78bfa;--good:#4ade80;--warn:#fbbf24;--danger:#fb7185;--shadow:0 18px 55px rgba(0,0,0,.25)}}
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;min-height:100vh;background:radial-gradient(circle at 88% -10%,rgba(124,58,237,.22),transparent 31%),radial-gradient(circle at -8% 16%,rgba(37,99,235,.18),transparent 27%),var(--bg);color:var(--text)}
button,input,select{font:inherit}.wrap{width:min(980px,100%);margin:auto;padding:14px 14px calc(80px + env(safe-area-inset-bottom))}.topbar{position:sticky;top:0;z-index:20;display:flex;align-items:center;justify-content:space-between;gap:12px;padding:10px 4px 12px;background:linear-gradient(var(--bg) 58%,transparent);backdrop-filter:blur(14px)}.brand{display:flex;align-items:center;gap:10px}.logo{width:42px;height:42px;border-radius:14px;display:grid;place-items:center;background:linear-gradient(135deg,var(--accent),var(--accent2));color:white;font-size:21px;box-shadow:0 10px 28px rgba(37,99,235,.28)}.brand strong{display:block;font-size:16px}.brand small{color:var(--muted)}
.pill{display:inline-flex;align-items:center;gap:6px;padding:7px 10px;border:1px solid var(--line);border-radius:999px;background:var(--card2);font-size:12px;color:var(--muted)}.dot{width:8px;height:8px;border-radius:50%;background:var(--warn)}.dot.good{background:var(--good)}
.hero{padding:20px 4px 18px}.hero h1{font-size:clamp(29px,7vw,46px);line-height:1.05;letter-spacing:-.035em;margin:0 0 10px}.gradient{background:linear-gradient(100deg,var(--accent),var(--accent2));-webkit-background-clip:text;background-clip:text;color:transparent}.hero p{max-width:720px;margin:0;color:var(--muted);line-height:1.7}.notice{margin-top:14px;padding:11px 13px;border-radius:14px;border:1px solid var(--line);background:var(--card2);font-size:13px;line-height:1.55}
.grid{display:grid;grid-template-columns:1fr;gap:14px}.card{background:var(--card);backdrop-filter:blur(22px);border:1px solid var(--line);border-radius:22px;padding:17px;box-shadow:var(--shadow)}.card h2{font-size:18px;margin:0}.card-head{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:13px}.sub{color:var(--muted);font-size:12px;line-height:1.5}.row{display:flex;gap:10px;flex-wrap:wrap}.field{flex:1;min-width:160px}.field.small{max-width:150px}label{display:block;font-size:12px;color:var(--muted);margin:0 0 6px}input,select{width:100%;min-height:44px;padding:10px 12px;border:1px solid var(--line);border-radius:13px;background:rgba(255,255,255,.04);color:var(--text);outline:none}input:focus,select:focus{border-color:var(--accent);box-shadow:0 0 0 3px color-mix(in srgb,var(--accent) 17%,transparent)}
.actions{display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-top:11px}button,.btn{min-height:40px;border:0;border-radius:13px;padding:9px 13px;background:linear-gradient(135deg,var(--accent),color-mix(in srgb,var(--accent) 72%,var(--accent2)));color:white;font-weight:680;text-decoration:none;display:inline-flex;align-items:center;justify-content:center;gap:6px;cursor:pointer;box-shadow:0 7px 20px rgba(37,99,235,.16)}button:disabled{opacity:.55;cursor:not-allowed}.secondary{background:transparent;color:var(--text);border:1px solid var(--line);box-shadow:none}.danger{background:var(--danger)}.ghost{background:transparent;color:var(--muted);box-shadow:none;padding:7px 9px}.smallbtn{min-height:34px;padding:7px 10px;font-size:12px;border-radius:11px}
.statusbar{display:none;margin-bottom:14px;padding:11px 13px;border-radius:14px;border:1px solid var(--line);background:var(--card2);font-size:13px}.statusbar.show{display:block}.statusbar.good{color:var(--good)}.statusbar.error{color:var(--danger)}.statusbar.warn{color:var(--warn)}
.account{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px;border:1px solid var(--line);border-radius:16px;background:var(--card2)}.account-main{min-width:0}.account-main strong{display:block;white-space:nowrap;overflow:hidden;