text-overflow:ellipsis}.account-meta{font-size:12px;color:var(--muted);margin-top:4px}.goodtext{color:var(--good)}.warntext{color:var(--warn)}.badtext{color:var(--danger)}
.chips{display:flex;gap:7px;overflow:auto;padding:2px 0 4px;scrollbar-width:none}.chip{flex:0 0 auto;border:1px solid var(--line);border-radius:999px;padding:7px 10px;background:var(--card2);color:var(--text);font-size:12px;box-shadow:none;min-height:32px}.results{display:grid;gap:10px;margin-top:13px}.app{display:grid;grid-template-columns:66px minmax(0,1fr);gap:12px;padding:12px;border:1px solid var(--line);border-radius:17px;background:var(--card2)}.app img{width:66px;height:66px;border-radius:16px;background:var(--line);object-fit:cover}.app h3{font-size:16px;margin:1px 0 5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.meta{color:var(--muted);font-size:12px;line-height:1.55}.rating{color:var(--warn)}
.version-tools{display:flex;gap:8px;flex-wrap:wrap;margin:9px 0}.versions{max-height:520px;overflow:auto;border-top:1px solid var(--line)}.ver{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:10px;align-items:center;padding:11px 0;border-bottom:1px solid var(--line)}.ver strong{font-size:15px}.ver .actions{margin:0}.skeleton{height:82px;border-radius:16px;background:linear-gradient(90deg,var(--card2),color-mix(in srgb,var(--card2) 70%,white),var(--card2));background-size:200% 100%;animation:shine 1.2s linear infinite}@keyframes shine{to{background-position:-200% 0}}
.library{display:grid;grid-template-columns:1fr 1fr;gap:12px}.list{display:grid;gap:8px}.list-item{display:flex;align-items:center;justify-content:space-between;gap:9px;padding:10px;border:1px solid var(--line);border-radius:14px;background:var(--card2)}.list-item .text{min-width:0}.list-item strong{display:block;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.list-item small{color:var(--muted)}.empty{padding:18px 8px;text-align:center;color:var(--muted);font-size:13px}.diag{display:grid;gap:8px}.diag-row{display:grid;grid-template-columns:1fr auto;gap:10px;padding:9px 0;border-bottom:1px solid var(--line);font-size:13px}
.hidden{display:none!important}.modal{position:fixed;inset:0;z-index:60;display:none;align-items:flex-end;justify-content:center;background:rgba(2,6,23,.54);padding:14px}.modal.show{display:flex}.sheet{width:min(620px,100%);max-height:88vh;overflow:auto;border-radius:24px 24px 18px 18px;padding:18px;background:var(--bg);border:1px solid var(--line);box-shadow:0 30px 90px rgba(0,0,0,.38)}.sheet-head{display:flex;align-items:flex-start;justify-content:space-between;gap:12px}.sheet-app{display:flex;gap:12px;align-items:center}.sheet-app img{width:64px;height:64px;border-radius:16px}.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin:14px 0}.detail{padding:11px;border:1px solid var(--line);border-radius:14px;background:var(--card2)}.detail small{display:block;color:var(--muted);margin-bottom:4px}.detail strong{font-size:13px;word-break:break-all}.download-primary{width:100%;min-height:50px;font-size:16px}.foot{margin-top:16px;color:var(--muted);font-size:12px;line-height:1.65;text-align:center}
@media(min-width:820px){.grid.two{grid-template-columns:1fr 1fr}.span2{grid-column:1/-1}}@media(max-width:640px){.library{grid-template-columns:1fr}.app{grid-template-columns:56px minmax(0,1fr)}.app img{width:56px;height:56px}.ver{grid-template-columns:1fr}.ver .actions{justify-content:flex-start}.detail-grid{grid-template-columns:1fr}.field.small{max-width:none}.account{align-items:flex-start;flex-direction:column}}
</style>
</head>
<body>
<main class="wrap">
  <div class="topbar">
    <div class="brand"><div class="logo">⬇︎</div><div><strong>IPA Tool Enhanced</strong><small>Loon 本地增强版</small></div></div>
    <div class="pill"><span id="healthDot" class="dot"></span><span id="healthText">初始化</span></div>
  </div>
  <header class="hero">
    <h1>更稳、更快地管理<br><span class="gradient">App Store 历史版本</span></h1>
    <p>兼容原版 IPA 工具箱接口，同时提供完全独立的本地面板。账号会话、版本缓存、收藏与历史记录都保存在本机。</p>
    <div class="notice">下载采用 <strong>302 直跳 Apple CDN</strong>，Loon 不代理 IPA 文件内容，避免中转限速。版本大小等详细信息仅在点击时查询，减少卡顿和无效请求。</div>
  </header>
  <div id="statusbar" class="statusbar"></div>

  <div class="grid two">
    <section class="card">
      <div class="card-head"><div><h2>Apple ID 会话</h2><div class="sub">密码默认不会保存；可在插件参数中选择是否允许自动刷新 Cookie</div></div></div>
      <div id="accountBox" class="empty">正在读取账号状态…</div>
      <form id="loginForm">
        <div class="row">
          <div class="field"><label>Apple ID</label><input id="appleId" type="text" autocomplete="username" autocapitalize="none" autocorrect="off" spellcheck="false" required placeholder="邮箱或手机号（例如 +86138...）"></div>
          <div class="field"><label>密码</label><input id="password" type="password" autocomplete="current-password" required></div>
          <div id=