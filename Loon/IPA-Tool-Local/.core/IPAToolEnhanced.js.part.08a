'+esc(a.bundleId||'')+'<br>最新 '+esc(a.version||'未知')+' · '+esc(a.price==null?'':a.price)+' · '+bytes(a.fileSize)+(a.averageUserRating?'<span class="rating"> · ★ '+Number(a.averageUserRating).toFixed(1)+'</span>':'')+'</div><div class="actions"><button class="smallbtn js-versions" data-id="'+esc(a.appId)+'" data-name="'+esc(a.name)+'">历史版本</button><button class="secondary smallbtn js-latest" data-id="'+esc(a.appId)+'">下载最新版</button><button class="secondary smallbtn js-favorite" data-id="'+esc(a.appId)+'" data-name="'+esc(a.name)+'" data-bundle="'+esc(a.bundleId||'')+'" data-icon="'+esc(a.icon||'')+'">'+(favorite?'取消收藏':'收藏')+'</button><button class="ghost smallbtn js-purchase" data-id="'+esc(a.appId)+'">获取免费许可</button></div></div></article>'}
async function search(term,country){term=String(term||'').trim();const originalCountry=String(country||DEFAULT_COUNTRY).trim();country=normalizeCountryInput(originalCountry)||normalizeCountryInput(DEFAULT_COUNTRY)||'us';$('#country').value=country;if(!term)return;$('#results').innerHTML='<div class="skeleton"></div><div class="skeleton"></div>';$('#resultSummary').textContent='正在查询 App Store…';try{let list;if(/^\d+$/.test(term)){const one=await api('/api/lookup?id='+encodeURIComponent(term)+'&country='+encodeURIComponent(country));list=one?[one]:[]}else{list=await api('/api/search?term='+encodeURIComponent(term)+'&country='+encodeURIComponent(country))}$('#results').innerHTML=list.length?list.map(appCard).join(''):'<div class="empty">没有找到结果</div>';$('#resultSummary').textContent='找到 '+list.length+' 个结果';refresh()}catch(e){$('#results').innerHTML='<div class="empty badtext">'+esc(e.message)+'</div>';$('#resultSummary').textContent='搜索失败'}}
function renderVersions(){const q=$('#versionFilter').value.trim().toLowerCase();const rows=model.versions.filter(v=>!q||String(v[0]).toLowerCase().includes(q)||String(v[1]).toLowerCase().includes(q));$('#versions').innerHTML=rows.length?rows.map(v=>'<div class="ver"><div><strong>'+esc(v[1]||'????')+'</strong><div class="meta">External ID '+esc(v[0])+'</div></div><div class="actions"><button class="smallbtn js-prepare" data-id="'+esc(model.currentApp.id)+'" data-version="'+esc(v[0])+'">查看下载详情</button></div></div>').join(''):'<div class="empty">没有匹配版本</div>'}
async function showVersions(id,name,force){model.currentApp={id:String(id),name:name||'App'};$('#versionCard').classList.remove('hidden');$('#versionTitle').textContent=(name||'App')+' · 历史版本';$('#versionInfo').textContent='正在读取版本索引…';$('#versions').innerHTML='<div class="skeleton"></div><div class="skeleton"></div>';location.hash='versions';try{const r=await api('/api/versions?id='+encodeURIComponent(id)+(force?'&force=1':''));model.versions=r.data||[];$('#versionInfo').textContent='共 '+r.total+' 个版本 · '+r.source+(r.cached?' · 本地缓存':' · 刚刚更新')+(r.providerErrors&&r.providerErrors.length?' · 部分版本源不可用':'');renderVersions()}catch(e){$('#versions').innerHTML='<div class="empty badtext">'+esc(e.message)+'</div>';$('#versionInfo').textContent='读取失败'}}
async function prepareDownload(id,version){showStatus('正在向 Apple 查询该版本详细信息…');try{const d=await api('/api/download/prepare?id='+encodeURIComponent(id)+'&version='+encodeURIComponent(version||''));model.prepared=d;$('#sheetApp').innerHTML='<img src="'+esc(d.icon||'')+'" alt=""><div><strong>'+esc(d.name)+'</strong><div class="meta">'+esc(d.bundleId)+'<br>版本 '+esc(d.displayVersion||'未知')+' ('+esc(d.buildVersion||'')+')</div></div>';$('#sheetDetails').innerHTML='<div class="detail"><small>文件大小</small><strong>'+bytes(d.fileSize)+'</strong></div><div class="detail"><small>最低系统</small><strong>iOS '+esc(d.minimumOsVersion||'未知')+'</strong></div><div class="detail"><small>External ID</small><strong>'+esc(d.externalVersionId||'')+'</strong></div><div class="detail"><small>下载账号</small><strong>'+esc(d.account||'')+'</strong></div>';const q='?id='+encodeURIComponent(id)+'&version='+encodeURIComponent(version||'')+'&token='+encodeURIComponent(TOKEN);$('#downloadLink').href='/api/download'+q;$('#metadataLink').href='/api/metadata'+q;$('#sinfLink').href='/api/sinf'+q;$('#downloadModal').classList.add('show');$('#downloadModal').setAttribute('aria-hidden','false');showStatus('下载信息已准备好','good');refresh()}catch(e){showStatus(e.message,'error')}}
async function toggleFavorite(button){try{await api('/api/favorite/toggle',{method:'POST',body:{appId:button.dataset.id,name:button.dataset.name,bundleId:button.dataset.bundle,icon:button.dataset.icon}});await refresh();button.textContent=button.textContent==='收藏'?'取消收藏':'收藏'}catch(e){showStatus(e.message,'error')}}
async function purchase(id){if(!confirm('仅支持免费应用。确定向 Apple 请求该应用许可吗？'))return;showStatus('正在请求免费许可…');try{await api('/api/purchase',{method:'POST',body:{appId:id}});showStatus('许可请求已提交，可重新获取版本信息','good')}catch(e){showStatus(e.message,'error')}}
function setTwoFactorMode(enabled){const row=