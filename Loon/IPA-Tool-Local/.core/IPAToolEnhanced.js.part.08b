$('#twoFactorRow'),button=$('#loginBtn'),code=$('#code');row.classList.toggle('hidden',!enabled);code.required=!!enabled;button.textContent=enabled?'提交验证码并登录':'登录并保存会话';if(!enabled)code.value=''}
$('#loginForm').addEventListener('submit',async e=>{e.preventDefault();const code=$('#code').value.trim();showStatus(code?'正在验证双重认证码…':'正在登录 Apple ID…');try{const a=await api('/api/login',{method:'POST',body:{appleId:$('#appleId').value,password:$('#password').value,code}});$('#password').value='';setTwoFactorMode(false);showStatus('登录成功：'+a.appleId,'good');refresh()}catch(err){if(err.requiresTwoFactor||err.code==='TWO_FACTOR_REQUIRED'||/MZFinance\.BadLogin\.Configurator_message/i.test(err.message)){setTwoFactorMode(true);showStatus(err.message||'Apple 需要双重认证，请输入 6 位验证码','warn');setTimeout(()=>{$('#code').focus();$('#twoFactorRow').scrollIntoView({behavior:'smooth',block:'center'})},80)}else{showStatus(err.message,'error')}}});
$('#refreshSessionBtn').addEventListener('click',async()=>{showStatus('正在刷新 Cookie…');try{await api('/api/account/refresh',{method:'POST',body:{}});showStatus('Cookie 已刷新','good');refresh()}catch(e){showStatus(e.message,'error')}});
$('#accountBox').addEventListener('click',async e=>{const sw=e.target.closest('.js-switch');const rm=e.target.closest('.js-remove-account');try{if(sw){await api('/api/account/switch',{method:'POST',body:{appleId:sw.dataset.id}});showStatus('账号已切换','good');refresh()}if(rm&&confirm('移除此账号的本地会话？')){await api('/api/logout',{method:'POST',body:{appleId:rm.dataset.id}});showStatus('本地会话已移除','good');refresh()}}catch(err){showStatus(err.message,'error')}});
$('#searchForm').addEventListener('submit',e=>{e.preventDefault();search($('#term').value,$('#country').value)});
$('#clearSearchBtn').addEventListener('click',()=>{$('#term').value='';$('#results').innerHTML='<div class="empty">还没有搜索内容</div>';$('#resultSummary').textContent='搜索后显示应用'});
$('#searchHistory').addEventListener('click',e=>{const b=e.target.closest('.js-history');if(!b)return;$('#term').value=b.dataset.term;$('#country').value=b.dataset.country||DEFAULT_COUNTRY;search(b.dataset.term,b.dataset.country)});
$('#results').addEventListener('click',e=>{const v=e.target.closest('.js-versions');const l=e.target.closest('.js-latest');const f=e.target.closest('.js-favorite');const p=e.target.closest('.js-purchase');if(v)showVersions(v.dataset.id,v.dataset.name,false);else if(l)prepareDownload(l.dataset.id,'');else if(f)toggleFavorite(f);else if(p)purchase(p.dataset.id)});
$('#favorites').addEventListener('click',e=>{const b=e.target.closest('.js-favorite-open');if(b)showVersions(b.dataset.id,b.dataset.name,false)});
$('#downloadHistory').addEventListener('click',e=>{const b=e.target.closest('.js-history-download');if(b)prepareDownload(b.dataset.id,b.dataset.version)});
$('#versions').addEventListener('click',e=>{const b=e.target.closest('.js-prepare');if(b)prepareDownload(b.dataset.id,b.dataset.version)});
$('#versionFilter').addEventListener('input',renderVersions);
$('#forceVersions').addEventListener('click',()=>model.currentApp&&showVersions(model.currentApp.id,model.currentApp.name,true));
$('#closeVersions').addEventListener('click',()=>$('#versionCard').classList.add('hidden'));
$('#settingsForm').addEventListener('submit',async e=>{e.preventDefault();try{const country=normalizeCountryInput($('#settingCountry').value);if(!country)throw new Error('请输入有效的商店地区，例如 cn、us、hk；zh 会自动转换为 cn');$('#settingCountry').value=country;await api('/api/settings',{method:'POST',body:{country,cacheHours:$('#cacheHours').value}});$('#country').value=country;showStatus('设置已保存：'+country.toUpperCase(),'good');refresh()}catch(err){showStatus(err.message,'error')}});
$('#clearCacheBtn').addEventListener('click',async()=>{try{await api('/api/cache/clear',{method:'POST',body:{}});showStatus('版本缓存已清空','good')}catch(e){showStatus(e.message,'error')}});
$('#clearHistoryBtn').addEventListener('click',async()=>{if(!confirm('清空本地下载准备记录？'))return;try{await api('/api/history/clear',{method:'POST',body:{}});showStatus('下载记录已清空','good');refresh()}catch(e){showStatus(e.message,'error')}});
$('#diagnoseBtn').addEventListener('click',async()=>{showStatus('正在检测网络接口…');try{const d=await api('/api/diagnostics');renderDiagnostics(d);showStatus('网络检测完成','good')}catch(e){showStatus(e.message,'error')}});
$('#closeModal').addEventListener('click',()=>{$('#downloadModal').classList.remove('show');$('#downloadModal').setAttribute('aria-hidden','true')});
$('#downloadModal').addEventListener('click',e=>{if(e.target===$('#downloadModal'))$('#closeModal').click()});
$('#copyUrlBtn').addEventListener('click',async()=>{if(!model.prepared)return;try{await navigator.clipboard.writeText(model.prepared.url);showStatus('Apple CDN 地址已复制','good')}catch(e){prompt('复制下载地址',model.prepared.url)}});
